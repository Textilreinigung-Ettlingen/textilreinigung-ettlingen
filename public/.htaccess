<IfModule mod_rewrite.c>
  Options -MultiViews
  RewriteEngine On

  # In EINEM Schritt auf https + non-www kanonisieren
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.textilreinigung-ettlingen\.de$ [NC]
  RewriteRule ^(.*)$ https://textilreinigung-ettlingen.de/$1 [R=301,L]

  # SPA-Fallback: alle Routen ohne existierende Datei auf index.html umleiten
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>
